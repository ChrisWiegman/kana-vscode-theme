    "tokenColors": [
        {
            "name": "Comments",
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": { "foreground": "#6b6460", "fontStyle": "italic" }
        },
        {
            "name": "Doc comments",
            "scope": ["comment.block.documentation", "comment.line.documentation"],
            "settings": { "foreground": "#7a736c", "fontStyle": "italic" }
        },
        {
            "name": "Doc comment tags (@param, @return)",
            "scope": ["storage.type.class.jsdoc", "punctuation.definition.block.tag.jsdoc", "entity.name.tag.inline.jsdoc"],
            "settings": { "foreground": "#9a8878", "fontStyle": "italic" }
        },

        {
            "name": "Keywords — control flow",
            "scope": [
                "keyword.control",
                "keyword.control.flow",
                "keyword.control.import",
                "keyword.control.export",
                "keyword.control.from",
                "keyword.control.as"
            ],
            "settings": { "foreground": "#c8804a", "fontStyle": "italic" }
        },
        {
            "name": "Keywords — other",
            "scope": [
                "keyword",
                "keyword.operator.new",
                "keyword.operator.expression",
                "keyword.operator.cast",
                "keyword.operator.sizeof",
                "keyword.operator.instanceof",
                "keyword.operator.logical.python",
                "keyword.operator.in",
                "keyword.operator.of"
            ],
            "settings": { "foreground": "#c8804a", "fontStyle": "italic" }
        },
        {
            "name": "Storage — function/class/var declarators",
            "scope": ["storage", "storage.type", "storage.modifier"],
            "settings": { "foreground": "#c8804a", "fontStyle": "italic" }
        },

        {
            "name": "Strings",
            "scope": ["string", "string.quoted", "string.template"],
            "settings": { "foreground": "#98b060" }
        },
        {
            "name": "String escape sequences",
            "scope": ["constant.character.escape"],
            "settings": { "foreground": "#d4a87a" }
        },
        {
            "name": "Template expression punctuation",
            "scope": ["punctuation.definition.template-expression"],
            "settings": { "foreground": "#c8804a" }
        },
        {
            "name": "Regular expressions",
            "scope": ["string.regexp"],
            "settings": { "foreground": "#c8a060" }
        },
        {
            "name": "Regex groups and quantifiers",
            "scope": [
                "punctuation.definition.group.regexp",
                "keyword.operator.quantifier.regexp",
                "keyword.operator.or.regexp"
            ],
            "settings": { "foreground": "#c8804a" }
        },

        {
            "name": "Numbers — integer / float",
            "scope": [
                "constant.numeric",
                "constant.numeric.decimal",
                "constant.numeric.float",
                "constant.numeric.integer"
            ],
            "settings": { "foreground": "#c8a060" }
        },
        {
            "name": "Numbers — hex / octal / binary",
            "scope": [
                "constant.numeric.hex",
                "constant.numeric.octal",
                "constant.numeric.binary"
            ],
            "settings": { "foreground": "#d4a87a" }
        },

        {
            "name": "Boolean — true / false",
            "scope": ["constant.language.boolean"],
            "settings": { "foreground": "#7ab870", "fontStyle": "italic" }
        },
        {
            "name": "Null / nil / undefined / none",
            "scope": [
                "constant.language.null",
                "constant.language.undefined",
                "constant.language.nil",
                "constant.language.none"
            ],
            "settings": { "foreground": "#7ab870", "fontStyle": "italic" }
        },
        {
            "name": "Other language constants (this, self, super)",
            "scope": ["constant.language", "variable.language.this", "variable.language.self", "variable.language.super"],
            "settings": { "foreground": "#c8804a", "fontStyle": "italic" }
        },

        {
            "name": "Named / user-defined constants",
            "scope": ["variable.other.constant", "variable.other.enummember"],
            "settings": { "foreground": "#b06858" }
        },
        {
            "name": "Enum members",
            "scope": ["constant.other.enum"],
            "settings": { "foreground": "#b06858" }
        },

        {
            "name": "Variables",
            "scope": ["variable", "variable.other", "variable.other.readwrite"],
            "settings": { "foreground": "#c4b8ae" }
        },
        {
            "name": "Parameters",
            "scope": ["variable.parameter", "variable.parameter.function"],
            "settings": { "foreground": "#c4b8ae", "fontStyle": "italic" }
        },
        {
            "name": "Object properties",
            "scope": [
                "variable.other.property",
                "support.variable.property",
                "variable.other.object.property"
            ],
            "settings": { "foreground": "#b8a878" }
        },
        {
            "name": "Object literal keys",
            "scope": ["meta.object-literal.key"],
            "settings": { "foreground": "#d4a87a" }
        },

        {
            "name": "Functions — calls",
            "scope": [
                "entity.name.function",
                "meta.function-call.generic",
                "meta.function-call entity.name.function",
                "support.function"
            ],
            "settings": { "foreground": "#e8c87a" }
        },
        {
            "name": "Functions — definitions",
            "scope": ["meta.definition.function entity.name.function"],
            "settings": { "foreground": "#e8c87a", "fontStyle": "bold" }
        },
        {
            "name": "Built-in functions / support",
            "scope": ["support.function.builtin"],
            "settings": { "foreground": "#e8c87a" }
        },

        {
            "name": "Types and classes",
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "entity.other.inherited-class",
                "support.class",
                "support.type"
            ],
            "settings": { "foreground": "#d4a87a" }
        },
        {
            "name": "Interfaces",
            "scope": ["entity.name.type.interface"],
            "settings": { "foreground": "#80a898", "fontStyle": "italic" }
        },
        {
            "name": "Structs",
            "scope": ["entity.name.type.struct", "storage.type.struct"],
            "settings": { "foreground": "#d4a87a" }
        },
        {
            "name": "Enums",
            "scope": ["entity.name.type.enum"],
            "settings": { "foreground": "#b06858" }
        },
        {
            "name": "Type parameters / generics",
            "scope": [
                "entity.name.type.parameter",
                "variable.type.parameter",
                "punctuation.definition.typeparameters"
            ],
            "settings": { "foreground": "#80a898" }
        },
        {
            "name": "Built-in primitive types (int, string, bool, etc.)",
            "scope": [
                "support.type.primitive",
                "support.type.builtin",
                "support.type.builtin.go",
                "keyword.type"
            ],
            "settings": { "foreground": "#80a898" }
        },

        {
            "name": "Namespaces and modules",
            "scope": [
                "entity.name.namespace",
                "entity.name.module",
                "variable.other.object"
            ],
            "settings": { "foreground": "#8898a8" }
        },

        {
            "name": "Operators",
            "scope": [
                "keyword.operator",
                "keyword.operator.arithmetic",
                "keyword.operator.comparison",
                "keyword.operator.assignment",
                "keyword.operator.logical",
                "keyword.operator.bitwise",
                "keyword.operator.type",
                "keyword.operator.spread",
                "keyword.operator.optional"
            ],
            "settings": { "foreground": "#9a8878" }
        },
        {
            "name": "Punctuation",
            "scope": [
                "punctuation",
                "punctuation.definition",
                "punctuation.terminator",
                "punctuation.separator",
                "meta.brace"
            ],
            "settings": { "foreground": "#7a736c" }
        },

        {
            "name": "Decorators / annotations",
            "scope": [
                "meta.decorator",
                "punctuation.decorator",
                "entity.name.function.decorator",
                "storage.type.annotation",
                "meta.annotation"
            ],
            "settings": { "foreground": "#c8804a", "fontStyle": "italic" }
        },

        {
            "name": "HTML tags",
            "scope": ["entity.name.tag"],
            "settings": { "foreground": "#c8804a" }
        },
        {
            "name": "HTML attributes",
            "scope": ["entity.other.attribute-name"],
            "settings": { "foreground": "#d4a87a", "fontStyle": "italic" }
        },
        {
            "name": "HTML attribute values",
            "scope": ["string.quoted.double.html", "string.quoted.single.html"],
            "settings": { "foreground": "#98b060" }
        },
        {
            "name": "HTML doctype",
            "scope": ["meta.tag.sgml.doctype"],
            "settings": { "foreground": "#6b6460", "fontStyle": "italic" }
        },

        {
            "name": "CSS selectors — tag",
            "scope": ["entity.name.tag.css"],
            "settings": { "foreground": "#c8804a" }
        },
        {
            "name": "CSS selectors — class / id",
            "scope": [
                "entity.other.attribute-name.class.css",
